# modelpipe backend keys — copy to `.env` (same folder as your routes.json) and fill in.
# modelpipe auto-loads `.env` next to the config on start (or pass --env-file <path>).
# These are the env-var NAMES referenced by routes.example.json — only set the ones your
# routes actually use. NEVER commit your real .env (it is gitignored).

# Anthropic API key (only if a route uses a key instead of "passthrough").
ANTHROPIC_API_KEY=

# z.ai GLM Coding Plan token (Authorization: Bearer ...), from the z.ai console.
ZAI_API_KEY=

# DeepSeek API key, from platform.deepseek.com.
DEEPSEEK_API_KEY=

# OpenRouter API key (Authorization: Bearer ...), from openrouter.ai.
OPENROUTER_API_KEY=
